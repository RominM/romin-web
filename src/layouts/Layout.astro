---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Développeur web à Béziers | Romin — Sites vitrines pour artisans & commerçants',
  description = 'Développeur web freelance à Béziers. Je crée des sites vitrines sur-mesure pour les artisans, commerçants et indépendants du Biterrois. Devis gratuit, livraison en 2 à 4 semaines.'
} = Astro.props

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Romin — Développeur web freelance",
  "description": "Création de sites vitrines sur-mesure pour artisans, commerçants et indépendants dans le Biterrois et l'Hérault.",
  "url": "https://romin.dev",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Puisserguier",
    "addressRegion": "Hérault",
    "postalCode": "34620",
    "addressCountry": "FR"
  },
  "areaServed": [
    { "@type": "City", "name": "Béziers" },
    { "@type": "City", "name": "Narbonne" },
    { "@type": "City", "name": "Saint-Chinian" },
    { "@type": "City", "name": "Pézenas" },
    { "@type": "City", "name": "Agde" },
    { "@type": "City", "name": "Sérignan" },
    { "@type": "City", "name": "Puisserguier" },
    { "@type": "AdministrativeArea", "name": "Hérault" },
    { "@type": "AdministrativeArea", "name": "Aude" }
  ],
  "priceRange": "€€",
  "knowsLanguage": "fr"
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <!-- Spots de couleur animés — z-index 0, fixed, clippé -->
    <div class="bg" aria-hidden="true">
      <div class="bg__spot bg__spot--1"></div>
      <div class="bg__spot bg__spot--2"></div>
      <div class="bg__spot bg__spot--3"></div>
    </div>

    <!-- Contenu de la page — z-index 1 -->
    <div class="page">
      <slot />
    </div>
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
  @use '../styles/foundations/variables' as *;

  /* ---- Background spots ---- */
  .bg {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .bg__spot {
    position: absolute;
    border-radius: 50%;

    &--1 {
      width: 800px;
      height: 800px;
      background: radial-gradient(circle at center, rgba(123, 105, 248, 0.2) 0%, transparent 65%);
      top: -300px;
      right: -200px;
      animation: spot-drift-1 22s ease-in-out infinite;
    }

    &--2 {
      width: 700px;
      height: 700px;
      background: radial-gradient(circle at center, rgba(248, 124, 109, 0.16) 0%, transparent 65%);
      bottom: -200px;
      left: -180px;
      animation: spot-drift-2 28s ease-in-out infinite;
    }

    &--3 {
      width: 550px;
      height: 550px;
      background: radial-gradient(circle at center, rgba(183, 168, 252, 0.14) 0%, transparent 65%);
      top: 40%;
      right: 8%;
      animation: spot-drift-3 35s ease-in-out infinite;
    }
  }

  @keyframes spot-drift-1 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(-60px, 70px); }
    66%       { transform: translate(40px, -40px); }
  }

  @keyframes spot-drift-2 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(80px, -60px); }
    66%       { transform: translate(-40px, 40px); }
  }

  @keyframes spot-drift-3 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(-40px, 60px); }
    66%       { transform: translate(60px, -40px); }
  }

  /* ---- Page wrapper ---- */
  .page {
    position: relative;
    z-index: 1;
    isolation: isolate; // crée un stacking context propre sans interférer avec position:fixed
  }
</style>
