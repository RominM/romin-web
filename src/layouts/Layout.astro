---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Romin — Création de sites web pour artisans & commerçants',
  description = 'Je crée des sites web sur-mesure pour les artisans, commerçants et indépendants locaux. Devis gratuit, livraison en 2 à 4 semaines.'
} = Astro.props
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="bg" aria-hidden="true">
      <div class="bg__spot bg__spot--1"></div>
      <div class="bg__spot bg__spot--2"></div>
      <div class="bg__spot bg__spot--3"></div>
    </div>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
  @use '../styles/foundations/variables' as *;

  .bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .bg__spot {
    position: absolute;
    border-radius: 50%;

    &--1 {
      width: 900px;
      height: 900px;
      background: radial-gradient(circle at center, rgba(123, 105, 248, 0.22) 0%, transparent 65%);
      top: -350px;
      right: -250px;
      animation: spot-drift-1 22s ease-in-out infinite;
    }

    &--2 {
      width: 750px;
      height: 750px;
      background: radial-gradient(circle at center, rgba(248, 124, 109, 0.18) 0%, transparent 65%);
      bottom: -250px;
      left: -200px;
      animation: spot-drift-2 28s ease-in-out infinite;
    }

    &--3 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle at center, rgba(183, 168, 252, 0.16) 0%, transparent 65%);
      top: 45%;
      right: 5%;
      animation: spot-drift-3 35s ease-in-out infinite;
    }
  }

  @keyframes spot-drift-1 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(-70px, 80px); }
    66%       { transform: translate(50px, -50px); }
  }

  @keyframes spot-drift-2 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(90px, -70px); }
    66%       { transform: translate(-50px, 50px); }
  }

  @keyframes spot-drift-3 {
    0%, 100% { transform: translate(0, 0); }
    33%       { transform: translate(-50px, 70px); }
    66%       { transform: translate(70px, -50px); }
  }

  body > *:not(.bg) {
    position: relative;
    z-index: 1;
  }
</style>
