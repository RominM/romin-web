---
---

<section id="contact" class="section">
  <div class="container">
    <div class="contact-box">
      <div class="contact-box__left reveal">
        <p class="section-label">Parlons de votre projet</p>
        <h2 class="section-title">Vous avez une idée ?<br />Je m'occupe du reste.</h2>
        <p class="section-desc">
          Décrivez-moi votre activité et ce que vous attendez de votre site.
          Je vous réponds sous 24h avec un premier retour gratuit.
        </p>

        <div class="contact-box__reassurance">
          <div class="contact-reassurance-item">
            <span>⚡</span>
            <span>Réponse sous 24h</span>
          </div>
          <div class="contact-reassurance-item">
            <span>🎁</span>
            <span>Devis 100 % gratuit</span>
          </div>
          <div class="contact-reassurance-item">
            <span>🤝</span>
            <span>Sans engagement</span>
          </div>
        </div>
      </div>

      <form class="contact-form reveal reveal-delay-2" name="contact" method="POST" action="/.netlify/functions/contact">

        <div class="contact-form__group">
          <label for="name">Votre nom</label>
          <input type="text" id="name" name="name" placeholder="Marie Dupont" required />
        </div>
        <div class="contact-form__group">
          <label for="business">Votre activité</label>
          <input type="text" id="business" name="business" placeholder="Ex : coiffeuse, restaurant, plombier…" required />
        </div>
        <div class="contact-form__group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="vous@exemple.fr" required />
        </div>
        <div class="contact-form__group">
          <label for="message">Votre projet en quelques mots</label>
          <textarea id="message" name="message" rows="4" placeholder="Je n'ai pas encore de site, je voudrais quelque chose de simple pour présenter mes services…" required></textarea>
        </div>
        <button type="submit" class="btn btn--coral">Envoyer ma demande →</button>
      </form>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundations' as *;

  .contact-box {
    display: grid;
    gap: 2rem;

    @include respond-to('lg') {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: 4rem;
    }

    &__left {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    &__reassurance {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  .contact-reassurance-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: $color-text-muted;

    span:first-child { font-size: 1rem; }
  }

  .contact-form {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: $radius-lg;
    padding: 1.25rem;
    box-shadow: 0 4px 24px rgba(120, 100, 180, 0.09);
    display: flex;

    @include respond-to('md') { padding: 2rem; }
    flex-direction: column;
    gap: 1.25rem;

    &__group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;

      label {
        font-size: 0.85rem;
        font-weight: 600;
        color: $color-text;
      }

      input, textarea {
        background: $color-bg;
        border: 1.5px solid $color-border;
        border-radius: $radius-sm;
        padding: 0.7rem 1rem;
        color: $color-text;
        font-size: 0.95rem;
        transition: border-color $transition, box-shadow $transition;
        resize: vertical;

        &::placeholder { color: $color-text-subtle; }

        &:focus {
          outline: none;
          border-color: $color-accent;
          box-shadow: 0 0 0 3px rgba($color-accent, 0.1);
        }
      }
    }
  }
</style>
