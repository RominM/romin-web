---
const navLinks = [
  { label: 'Prestations', href: '#services' },
  { label: 'Pourquoi moi', href: '#why' },
  { label: 'Réalisations', href: '#projects' },
  { label: 'Contact', href: '#contact' },
]
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo">romin<span>.</span>dev</a>
    <nav class="header__nav">
      {navLinks.map(link => (
        <a href={link.href} class="header__link">{link.label}</a>
      ))}
    </nav>
    <a href="#contact" class="btn btn--primary header__cta">Devis gratuit</a>
  </div>
</header>

<style lang="scss">
  @use '../styles/foundations' as *;

  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    background: rgba(253, 252, 251, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid $color-border;

    &__inner {
      @include flex-between;
      height: 68px;
    }

    &__logo {
      font-size: 1.15rem;
      font-weight: 700;
      color: $color-text;
      letter-spacing: -0.02em;

      span { color: $color-accent; }
    }

    &__nav {
      display: none;
      gap: 2.5rem;

      @include respond-to('md') {
        display: flex;
      }
    }

    &__link {
      font-size: 0.9rem;
      font-weight: 500;
      color: $color-text-muted;
      transition: color $transition;

      &:hover { color: $color-accent; }
    }

    &__cta {
      display: none;

      @include respond-to('md') {
        display: inline-flex;
      }
    }
  }
</style>
