---
const projects = [
  {
    emoji: '✂️',
    type: 'Salon de coiffure',
    title: 'Atelier Fauve',
    desc: 'Site vitrine avec prise de rendez-vous en ligne, galerie photos et présentation des prestations.',
    tags: ['Site vitrine', 'Réservation', 'Mobile-first'],
    link: '#',
  },
  {
    emoji: '🍕',
    type: 'Restaurant',
    title: 'La Braise',
    desc: 'Menu digital, carte des vins, réservation de table et mise en avant des plats du jour.',
    tags: ['Menu digital', 'Réservation', 'SEO local'],
    link: '#',
  },
  {
    emoji: '🔧',
    type: 'Artisan plombier',
    title: 'Plomberie Durand',
    desc: 'Site d\'urgence plomberie avec numéro d\'appel mis en avant, zone d\'intervention et formulaire de contact rapide.',
    tags: ['Site vitrine', 'Google Business', 'Contact rapide'],
    link: '#',
  },
]
---

<section id="projects" class="section projects-section">
  <div class="container">
    <p class="section-label">Réalisations</p>
    <h2 class="section-title">Des sites qui ressemblent à leurs propriétaires</h2>
    <p class="section-desc">
      Chaque projet est unique, pensé pour le métier et les clients du commerçant.
    </p>

    <div class="projects-grid">
      {projects.map(p => (
        <article class="project-card">
          <div class="project-card__cover">
            <span class="project-card__emoji">{p.emoji}</span>
            <span class="project-card__type">{p.type}</span>
          </div>
          <div class="project-card__body">
            <h3 class="project-card__title">{p.title}</h3>
            <p class="project-card__desc">{p.desc}</p>
            <div class="project-card__tags">
              {p.tags.map(tag => (
                <span class="project-card__tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="projects-note">
      Ces exemples illustrent le type de projets que je réalise.
      <a href="#contact">Parlons du vôtre →</a>
    </p>
  </div>
</section>

<style lang="scss">
  @use 'sass:color';
  @use '../styles/foundations' as *;

  .projects-section {
    background: $color-bg-alt;
  }

  .projects-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;

    @include respond-to('md') {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project-card {
    background: $color-bg-card;
    border-radius: $radius-md;
    overflow: hidden;
    box-shadow: $shadow-md;
    transition: transform $transition, box-shadow $transition;

    &:hover {
      transform: translateY(-4px);
      box-shadow: $shadow-lg;
    }

    &__cover {
      height: 130px;
      background: linear-gradient(135deg, $color-accent-bg, color.adjust($color-coral-bg, $lightness: 2%));
      @include flex-center;
      flex-direction: column;
      gap: 0.5rem;
      position: relative;
    }

    &__emoji {
      font-size: 2.5rem;
      line-height: 1;
    }

    &__type {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: $color-accent;
      background: $color-bg-card;
      padding: 0.2rem 0.6rem;
      border-radius: $radius-pill;
    }

    &__body {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    &__title {
      font-size: 1.05rem;
      color: $color-text;
    }

    &__desc {
      font-size: 0.88rem;
      color: $color-text-muted;
      line-height: 1.6;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    &__tag {
      font-size: 0.75rem;
      color: $color-accent;
      background: $color-accent-bg;
      padding: 0.2rem 0.6rem;
      border-radius: $radius-pill;
      font-weight: 500;
    }
  }

  .projects-note {
    margin-top: 2.5rem;
    text-align: center;
    font-size: 0.9rem;
    color: $color-text-subtle;

    a {
      color: $color-accent;
      font-weight: 600;
      transition: opacity $transition;

      &:hover { opacity: 0.75; }
    }
  }
</style>
