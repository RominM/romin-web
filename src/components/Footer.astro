---
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__logo">romin<span>.</span>dev</span>
      <p class="footer__tagline">Développeur web freelance — Puisserguier (34)</p>
      <p class="footer__zone">Béziers · Narbonne · Saint-Chinian · Pézenas · Agde & alentours</p>
    </div>
    <div class="footer__links">
      <a href="#services">Prestations</a>
      <a href="#why">Pourquoi moi</a>
      <a href="#contact">Contact</a>
    </div>
    <p class="footer__copy">© {year} Romin — Développeur web freelance à Béziers</p>
  </div>
</footer>

<style lang="scss">
  @use '../styles/foundations' as *;

  .footer {
    border-top: 1px solid $color-border;
    padding-block: 2.5rem;
    padding-bottom: calc(2.5rem + 72px); // espace pour le sticky CTA mobile
    background: $color-bg;

    @include respond-to('md') {
      padding-bottom: 2.5rem;
    }

    &__inner {
      display: grid;
      gap: 1.5rem;

      @include respond-to('md') {
        grid-template-columns: 1fr auto auto;
        align-items: center;
      }
    }

    &__brand {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__logo {
      font-size: 1.05rem;
      font-weight: 700;
      color: $color-text;

      span { color: $color-accent; }
    }

    &__tagline {
      font-size: 0.8rem;
      color: $color-text-subtle;
    }

    &__zone {
      font-size: 0.72rem;
      color: $color-text-subtle;
      opacity: 0.7;
    }

    &__links {
      display: flex;
      gap: 1.5rem;
      font-size: 0.85rem;
      color: $color-text-muted;

      a:hover { color: $color-accent; }
    }

    &__copy {
      font-size: 0.8rem;
      color: $color-text-subtle;
    }
  }
</style>
