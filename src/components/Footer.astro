---
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__logo">romin<span>.</span>dev</span>
      <p class="footer__tagline">Sites web pour artisans & commerçants locaux</p>
    </div>
    <div class="footer__links">
      <a href="#services">Prestations</a>
      <a href="#why">Pourquoi moi</a>
      <a href="#contact">Contact</a>
    </div>
    <p class="footer__copy">© {year} Romin — Développeur web freelance</p>
  </div>
</footer>

<style lang="scss">
  @use '../styles/foundations' as *;

  .footer {
    border-top: 1px solid $color-border;
    padding-block: 2.5rem;
    background: $color-bg;

    &__inner {
      display: grid;
      gap: 1.5rem;

      @include respond-to('md') {
        grid-template-columns: 1fr auto auto;
        align-items: center;
      }
    }

    &__brand {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__logo {
      font-size: 1.05rem;
      font-weight: 700;
      color: $color-text;

      span { color: $color-accent; }
    }

    &__tagline {
      font-size: 0.8rem;
      color: $color-text-subtle;
    }

    &__links {
      display: flex;
      gap: 1.5rem;
      font-size: 0.85rem;
      color: $color-text-muted;

      a:hover { color: $color-accent; }
    }

    &__copy {
      font-size: 0.8rem;
      color: $color-text-subtle;
    }
  }
</style>
