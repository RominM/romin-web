---
const reasons = [
  {
    icon: '💬',
    title: 'Zéro jargon',
    desc: 'Je vous explique tout en clair, sans termes techniques. Vous savez à tout moment où en est votre projet.',
  },
  {
    icon: '⚡',
    title: 'Rapide à livrer',
    desc: 'Votre site est en ligne en 2 à 4 semaines. Pas de longs mois d\'attente avant de commencer à être visible.',
  },
  {
    icon: '💶',
    title: 'Prix transparent',
    desc: 'Devis gratuit, tarif fixé à l\'avance. Pas de mauvaise surprise sur la facture finale.',
  },
  {
    icon: '🤝',
    title: 'Un seul interlocuteur',
    desc: 'C\'est moi qui fais le travail, du premier échange à la mise en ligne. Pas d\'intermédiaire, pas de délégation.',
  },
  {
    icon: '📡',
    title: 'Disponible 24h/24',
    desc: 'Votre site est surveillé automatiquement, toute l\'année. Si ça tombe un dimanche à 3h du matin, je suis alerté avant vous — et avant vos clients.',
  },
  {
    icon: '🔒',
    title: 'Vous restez propriétaire',
    desc: 'Le site vous appartient. Je vous transmets tous les accès. Vous n\'êtes jamais pris en otage.',
  },
]
---

<section id="why" class="section">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Pourquoi moi</p>
      <h2 class="section-title">Ce qui fait la différence</h2>
      <p class="section-desc">
        Pas une agence, pas un template automatique. Un développeur qui prend le temps de comprendre votre activité.
      </p>
    </div>

    <div class="why-grid">
      {reasons.map((r, i) => (
        <div class={`why-card reveal reveal-delay-${i + 1}`}>
          <span class="why-card__icon">{r.icon}</span>
          <h3 class="why-card__title">{r.title}</h3>
          <p class="why-card__desc">{r.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundations' as *;

  .why-grid {
    display: grid;
    gap: 1.25rem;
    margin-top: 3rem;

    @include respond-to('md') {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to('lg') {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .why-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: $radius-md;
    background: rgba(255, 255, 255, 0.42);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.75);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      translate 0.7s cubic-bezier(0.22, 1, 0.36, 1);

    &:hover {
      border-color: rgba($color-accent, 0.35);
      box-shadow: $shadow-md;
      transform: translateY(-3px);
    }

    &__icon {
      font-size: 1.6rem;
      line-height: 1;
    }

    &__title {
      font-size: 1rem;
      font-weight: 600;
      color: $color-text;
    }

    &__desc {
      font-size: 0.88rem;
      color: $color-text-muted;
      line-height: 1.65;
    }
  }
</style>
