---
---

<section class="hero section">
  <div class="container hero__inner">
    <div class="hero__badge hero-anim-1">
      <span class="hero__badge-dot"></span>
      Disponible pour de nouveaux projets
    </div>

    <h1 class="hero__title hero-anim-2">
      Votre entreprise mérite<br />
      un site qui <span class="hero__title--accent">travaille pour vous</span>
    </h1>

    <p class="hero__desc hero-anim-3">
      Je crée des sites web sur-mesure pour les artisans, commerçants et indépendants locaux.
      Simple, rapide à mettre en ligne, et pensé pour ramener des clients.
    </p>

    <div class="hero__actions hero-anim-4" id="hero-cta">
      <a href="#contact" class="btn btn--primary">Demander un devis gratuit</a>
      <a href="#projects" class="btn btn--ghost">Voir des exemples</a>
    </div>

    <div class="hero__social-proof hero-anim-5">
      <div class="hero__sp-item">
        <strong>2–4 semaines</strong>
        <span>pour mettre en ligne</span>
      </div>
      <div class="hero__sp-divider"></div>
      <div class="hero__sp-item">
        <strong>100 %</strong>
        <span>sur-mesure</span>
      </div>
      <div class="hero__sp-divider"></div>
      <div class="hero__sp-item">
        <strong>Devis</strong>
        <span>gratuit & sans engagement</span>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundations' as *;

  .hero {
    padding-top: calc($section-padding + 68px);
    background: linear-gradient(160deg, $color-bg 60%, $color-bg-alt 100%);
    overflow: hidden;

    &__inner {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      max-width: 680px;
    }

    &__badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: $color-accent;
      background: $color-accent-bg;
      padding: 0.4rem 1rem;
      border-radius: $radius-pill;
      width: fit-content;
    }

    &__badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: $color-accent;
      animation: pulse-dot 2s infinite;
    }

    &__title {
      font-size: clamp(2.4rem, 6vw, 3.8rem);
      line-height: 1.12;
      color: $color-text;
      letter-spacing: -0.02em;

      &--accent {
        color: $color-accent;
        background: linear-gradient(135deg, $color-accent 0%, #b39dfc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
    }

    &__desc {
      font-size: 1.1rem;
      color: $color-text-muted;
      line-height: 1.75;
    }

    &__actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    &__social-proof {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      padding-top: 0.5rem;
    }

    &__sp-item {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;

      strong {
        font-size: 1rem;
        font-weight: 700;
        color: $color-text;
      }

      span {
        font-size: 0.78rem;
        color: $color-text-subtle;
      }
    }

    &__sp-divider {
      width: 1px;
      height: 32px;
      background: $color-border;
    }
  }

  // Load animations for hero
  .hero-anim-1 { animation: fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both; }
  .hero-anim-2 { animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both; }
  .hero-anim-3 { animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both; }
  .hero-anim-4 { animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.48s both; }
  .hero-anim-5 { animation: fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both; }
</style>
