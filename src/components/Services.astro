---
const services = [
  {
    icon: '🌐',
    color: 'violet',
    title: 'Site vitrine professionnel',
    desc: 'Un site clair, rapide et moderne qui présente votre activité, vos horaires, vos tarifs — et donne envie de vous contacter.',
    items: ['Design sur-mesure', 'Adapté mobile & tablette', 'Hébergement inclus la 1ère année'],
  },
  {
    icon: '📍',
    color: 'coral',
    title: 'Visibilité sur Google',
    desc: 'Apparaissez quand un client cherche votre métier près de chez lui. Je configure votre fiche Google et optimise votre référencement local.',
    items: ['Fiche Google Business', 'SEO local', 'Balises et mots-clés adaptés'],
  },
  {
    icon: '📅',
    color: 'violet',
    title: 'Réservation & contact',
    desc: 'Formulaire de contact, prise de rendez-vous en ligne, menu digital, carte interactive — selon ce dont vous avez besoin.',
    items: ['Formulaire de contact', 'Réservation en ligne', 'Menu / catalogue digital'],
  },
  {
    icon: '🛡️',
    color: 'coral',
    title: 'Maintenance & surveillance 24/7',
    desc: 'Votre site est surveillé en permanence. En cas de panne — même un vendredi soir — je suis alerté en moins d\'une minute et j\'interviens avant que vos clients ne s\'en aperçoivent.',
    items: ['Surveillance automatique 24h/24', 'Alerte instantanée si le site tombe', 'Mises à jour & sécurité incluses', 'Support réactif'],
  },
]
---

<section id="services" class="section services-section">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Ce que je propose</p>
      <h2 class="section-title">Tout ce qu'il faut pour exister en ligne</h2>
      <p class="section-desc">
        Des prestations simples, pensées pour les indépendants et commerçants — sans jargon, sans mauvaise surprise.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article class={`service-card service-card--${s.color} reveal reveal-delay-${i + 1}`}>
          <span class="service-card__icon">{s.icon}</span>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <ul class="service-card__list">
            {s.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundations' as *;

  .services-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;

    @include respond-to('md') {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-card {
    @include card;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease,
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      translate 0.7s cubic-bezier(0.22, 1, 0.36, 1);

    &:hover {
      transform: translateY(-6px);
      box-shadow: $shadow-lg;
    }

    &--violet .service-card__icon { background: $color-accent-bg; }
    &--coral  .service-card__icon { background: $color-coral-bg; }

    &__icon {
      width: 52px;
      height: 52px;
      border-radius: $radius-sm;
      @include flex-center;
      font-size: 1.5rem;
    }

    &__title {
      font-size: 1.1rem;
      color: $color-text;
    }

    &__desc {
      font-size: 0.9rem;
      color: $color-text-muted;
      line-height: 1.65;
      flex: 1;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding-top: 0.5rem;
      border-top: 1px solid $color-border;

      li {
        font-size: 0.82rem;
        color: $color-text-muted;
        padding-left: 1.1rem;
        position: relative;

        &::before {
          content: '✓';
          position: absolute;
          left: 0;
          color: $color-accent;
          font-weight: 700;
        }
      }
    }
  }
</style>
